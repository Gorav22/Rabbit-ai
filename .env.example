# ─── Multi-environment .env example ──────────────────────────────────────────
# Copy this to backend/.env and fill in your values.

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── SMTP Email Delivery ───────────────────────────────────────────────────────
# Gmail recommended. Enable 2FA + create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SENDER_NAME=Rabbitt AI — Sales Insights

# ── CORS ──────────────────────────────────────────────────────────────────────
# For Docker: http://localhost:3000
# For production: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# For Docker: http://localhost:8000
# For production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:8000
